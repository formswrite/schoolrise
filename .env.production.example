# =====================================================================
# SchoolRise — production environment template
# Copy to .env.production, replace every value, then `chmod 600`.
# =====================================================================

# --- DNS / TLS ---
# The single public hostname. ONE A record must point at the server IP:
#   <DOMAIN>  →  e.g. schoolrise.education.gov.gn
#
# MinIO is internal-only — no DNS, no public exposure. Files are served by
# SvelteKit's /api/uploads/[key] proxy under the same DOMAIN.
DOMAIN=schoolrise.example.com
LE_EMAIL=ops@example.com

# --- Postgres ---
POSTGRES_PASSWORD=__GENERATE_A_LONG_RANDOM_PASSWORD__

# --- Admin bootstrap ---
# Used at first boot to create the initial admin user. Rotate after first login.
ADMIN_EMAIL=admin@schoolrise.example.com
ADMIN_PASSWORD=__GENERATE_A_LONG_RANDOM_PASSWORD__
ADMIN_FULL_NAME=Administrator

# --- MinIO (object storage, internal-only) ---
# These credentials are used by SvelteKit's S3 client to talk to minio:9000
# inside the docker network. They are NOT exposed to browsers.
MINIO_ROOT_USER=schoolrise
MINIO_ROOT_PASSWORD=__GENERATE_A_LONG_RANDOM_PASSWORD__
MINIO_BUCKET=schoolrise-uploads
MINIO_REGION=us-east-1

# --- App settings ---
INSTANCE_NAME=SchoolRise
DEFAULT_LOCALE=en
TIME_ZONE=UTC
COUNTRY_PACK=
SCHOOLRISE_HEADLESS=

# --- Optional: external observability hooks (filled in once added) ---
# SENTRY_DSN=
# LOKI_URL=
