# =====================================================================
# SchoolRise — local development environment template
# Copy to .env (already gitignored) and fill in values.
#
# For production, see .env.production.example.
# =====================================================================

# --- Postgres (any non-empty value works for local) ---
POSTGRES_PASSWORD=__choose_a_local_password__

# --- Encore auth (any non-empty 32+ char value works for local) ---
AUTH_SECRET=__generate_with_openssl_rand_base64_32__

# --- App settings ---
TAG=latest
SCHOOLRISE_HEADLESS=
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=__choose_a_local_admin_password__
ADMIN_FULL_NAME=Local Admin
INSTANCE_NAME=SchoolRise (local dev)
DEFAULT_LOCALE=en
BASE_URL=http://localhost:3000
TIME_ZONE=UTC
COUNTRY_PACK=

# --- Optional observability ---
PROMETHEUS_SCRAPE_TOKEN=
SENTRY_DSN=

# --- MinIO (object storage for file uploads, local dev) ---
MINIO_ROOT_USER=schoolrise
MINIO_ROOT_PASSWORD=__choose_a_local_minio_password__
MINIO_BUCKET=schoolrise-uploads
MINIO_REGION=us-east-1
